{
  "name": "apologetics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/next-build.cjs",
    "start": "next start",
    "lint": "eslint",
    "test:auth": "tsx --test src/schemas/auth.test.ts src/lib/auth/permissions.test.ts",
    "test:news": "tsx --test src/schemas/news.test.ts src/lib/news-policy.test.ts",
    "test:event": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/event.test.ts src/lib/event-policy.test.ts src/services/event.service.test.ts",
    "test:magazine": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/magazine.test.ts src/lib/magazine-policy.test.ts src/services/magazine.service.test.ts",
    "test:category": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/category.test.ts src/lib/category-policy.test.ts src/services/category.service.test.ts",
    "test:tag": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/tag.test.ts src/lib/tag-policy.test.ts src/services/tag.service.test.ts",
    "test:user": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/user.test.ts src/lib/user-policy.test.ts src/services/user.service.test.ts",
    "test:message": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/schemas/contact-message.test.ts src/lib/contact-message-policy.test.ts src/services/contact-message.service.test.ts",
    "test:media": "tsx --env-file=.env --conditions=react-server --test --test-concurrency=1 src/config/uploads.test.ts src/lib/media-policy.test.ts src/services/media.service.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "media:cleanup": "tsx --env-file=.env --conditions=react-server scripts/media-cleanup.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@uploadthing/react": "^7.3.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
